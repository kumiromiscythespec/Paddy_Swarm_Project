{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:paddy-swarm:station-control:station-simulator-report:1",
  "title": "Paddy Swarm Station Simulator Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_version",
    "phase",
    "scenario_id",
    "result",
    "tick_count",
    "active_field_id",
    "fields",
    "rovers",
    "missions",
    "events_processed",
    "requests",
    "diagnostics",
    "safety",
    "summary",
    "exit_code"
  ],
  "properties": {
    "report_version": { "const": 1 },
    "phase": { "const": "ST-003" },
    "scenario_id": { "$ref": "#/$defs/identifier" },
    "result": { "enum": ["PASS", "FAIL"] },
    "tick_count": { "$ref": "#/$defs/nonNegativeInteger" },
    "active_field_id": { "enum": ["FIELD-DEMO-001", "FIELD-DEMO-002"] },
    "fields": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/field" },
      "allOf": [
        {
          "contains": {
            "properties": { "field_id": { "const": "FIELD-DEMO-001" } },
            "required": ["field_id"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": { "field_id": { "const": "FIELD-DEMO-002" } },
            "required": ["field_id"]
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "rovers": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/rover" },
      "allOf": [
        {
          "contains": {
            "properties": { "rover_id": { "const": "ROVER-DEMO-001" } },
            "required": ["rover_id"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": { "rover_id": { "const": "ROVER-DEMO-002" } },
            "required": ["rover_id"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": { "rover_id": { "const": "ROVER-DEMO-003" } },
            "required": ["rover_id"]
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "missions": {
      "type": "array",
      "items": { "$ref": "#/$defs/mission" }
    },
    "events_processed": {
      "type": "array",
      "items": { "$ref": "#/$defs/processedEvent" }
    },
    "requests": {
      "type": "array",
      "items": { "$ref": "#/$defs/request" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "safety": { "$ref": "#/$defs/safety" },
    "summary": { "$ref": "#/$defs/summary" },
    "exit_code": { "enum": [0, 2] }
  },
  "allOf": [
    {
      "if": { "properties": { "result": { "const": "PASS" } }, "required": ["result"] },
      "then": { "properties": { "exit_code": { "const": 0 } } },
      "else": { "properties": { "exit_code": { "const": 2 } } }
    },
    {
      "if": { "properties": { "exit_code": { "const": 0 } }, "required": ["exit_code"] },
      "then": { "properties": { "result": { "const": "PASS" } } },
      "else": { "properties": { "result": { "const": "FAIL" } } }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9-]{2,63}$"
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "display_name", "boundary_reference"],
      "properties": {
        "field_id": { "enum": ["FIELD-DEMO-001", "FIELD-DEMO-002"] },
        "display_name": { "enum": ["Field 1", "Field 2"] },
        "boundary_reference": {
          "type": "string",
          "pattern": "^local-reference:[a-z0-9-]{1,48}$"
        }
      }
    },
    "rover": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rover_id",
        "current_field_id",
        "current_unit_id",
        "official_state",
        "battery_percentage",
        "last_seen_tick",
        "fault",
        "active_mission_id",
        "communication_available"
      ],
      "properties": {
        "rover_id": { "enum": ["ROVER-DEMO-001", "ROVER-DEMO-002", "ROVER-DEMO-003"] },
        "current_field_id": { "enum": ["FIELD-DEMO-001", "FIELD-DEMO-002"] },
        "current_unit_id": { "$ref": "#/$defs/identifier" },
        "official_state": { "enum": ["STOPPED", "RUNNING", "RETURNING", "CHARGING"] },
        "battery_percentage": { "type": "integer", "minimum": 0, "maximum": 100 },
        "last_seen_tick": { "$ref": "#/$defs/nonNegativeInteger" },
        "fault": { "type": "string", "maxLength": 128 },
        "active_mission_id": { "type": "string", "maxLength": 64 },
        "communication_available": { "type": "boolean" }
      }
    },
    "missionState": {
      "enum": [
        "DRAFT",
        "WAITING_APPROVAL",
        "QUEUED",
        "ASSIGNED",
        "RUNNING",
        "PAUSED",
        "RETURNING",
        "CHARGING",
        "COMPLETED",
        "FAILED",
        "CANCELLED",
        "EXPIRED"
      ]
    },
    "mission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_id",
        "field_id",
        "required_unit_id",
        "assigned_rover_id",
        "state",
        "operator_approved",
        "automatic_resume_allowed"
      ],
      "properties": {
        "mission_id": { "$ref": "#/$defs/identifier" },
        "field_id": { "enum": ["FIELD-DEMO-001", "FIELD-DEMO-002"] },
        "required_unit_id": { "$ref": "#/$defs/identifier" },
        "assigned_rover_id": {
          "type": "string",
          "pattern": "^(|ROVER-DEMO-001|ROVER-DEMO-002|ROVER-DEMO-003)$"
        },
        "state": { "$ref": "#/$defs/missionState" },
        "operator_approved": { "type": "boolean" },
        "automatic_resume_allowed": { "const": false }
      }
    },
    "eventType": {
      "enum": [
        "BATTERY_SET",
        "BATTERY_DECREASE",
        "ROVER_SEEN",
        "COMMUNICATION_LOST",
        "COMMUNICATION_RESTORED",
        "FAULT_SET",
        "FAULT_CLEAR",
        "STOP_REQUEST",
        "RETURN_REQUEST",
        "MISSION_CREATE",
        "MISSION_APPROVE",
        "MISSION_ASSIGN",
        "MISSION_START",
        "MISSION_PAUSE",
        "MISSION_CANCEL",
        "CHARGE_START",
        "CHARGE_COMPLETE",
        "FIELD_SWITCH_REQUEST",
        "STATION_RESTART"
      ]
    },
    "processedEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tick", "input_order", "event_type", "target_id", "status", "reason"],
      "properties": {
        "tick": { "$ref": "#/$defs/nonNegativeInteger" },
        "input_order": { "$ref": "#/$defs/nonNegativeInteger" },
        "event_type": { "$ref": "#/$defs/eventType" },
        "target_id": { "$ref": "#/$defs/identifier" },
        "status": { "enum": ["ACCEPTED", "REJECTED"] },
        "reason": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tick", "request_type", "target_id", "accepted", "reason", "direct_output_authority"],
      "properties": {
        "tick": { "$ref": "#/$defs/nonNegativeInteger" },
        "request_type": { "enum": ["STOP_REQUEST", "RETURN_REQUEST", "FIELD_SWITCH_REQUEST"] },
        "target_id": { "$ref": "#/$defs/identifier" },
        "accepted": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 256 },
        "direct_output_authority": { "const": false }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "tick", "target_id", "message"],
      "properties": {
        "severity": { "enum": ["INFO", "WARNING", "ERROR"] },
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,79}$" },
        "tick": { "$ref": "#/$defs/nonNegativeInteger" },
        "target_id": { "$ref": "#/$defs/identifier" },
        "message": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_access_performed",
        "gpio_access_performed",
        "hardware_output_performed",
        "motor_control_performed",
        "charging_control_performed",
        "rover_output_authority",
        "physical_estop_independent",
        "automatic_resume_performed",
        "automatic_arm_performed"
      ],
      "properties": {
        "network_access_performed": { "const": false },
        "gpio_access_performed": { "const": false },
        "hardware_output_performed": { "const": false },
        "motor_control_performed": { "const": false },
        "charging_control_performed": { "const": false },
        "rover_output_authority": { "const": false },
        "physical_estop_independent": { "const": true },
        "automatic_resume_performed": { "const": false },
        "automatic_arm_performed": { "const": false }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_count",
        "rover_count",
        "mission_count",
        "event_count",
        "request_count",
        "diagnostic_count",
        "rejected_event_count"
      ],
      "properties": {
        "field_count": { "const": 2 },
        "rover_count": { "const": 3 },
        "mission_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "event_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "request_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "diagnostic_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "rejected_event_count": { "$ref": "#/$defs/nonNegativeInteger" }
      }
    }
  }
}
