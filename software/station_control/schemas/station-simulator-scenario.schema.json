{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:paddy-swarm:station-control:station-simulator-scenario:1",
  "title": "Paddy Swarm Station Simulator Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario_version",
    "scenario_id",
    "active_field_id",
    "fields",
    "rovers",
    "events"
  ],
  "properties": {
    "scenario_version": { "const": 1 },
    "scenario_id": { "$ref": "#/$defs/identifier" },
    "active_field_id": { "enum": ["FIELD-DEMO-001", "FIELD-DEMO-002"] },
    "fields": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/field" },
      "allOf": [
        {
          "contains": {
            "properties": {
              "field_id": { "const": "FIELD-DEMO-001" },
              "display_name": { "const": "Field 1" }
            },
            "required": ["field_id", "display_name"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": {
              "field_id": { "const": "FIELD-DEMO-002" },
              "display_name": { "const": "Field 2" }
            },
            "required": ["field_id", "display_name"]
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "rovers": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/rover" },
      "allOf": [
        {
          "contains": {
            "properties": { "rover_id": { "const": "ROVER-DEMO-001" } },
            "required": ["rover_id"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": { "rover_id": { "const": "ROVER-DEMO-002" } },
            "required": ["rover_id"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "properties": { "rover_id": { "const": "ROVER-DEMO-003" } },
            "required": ["rover_id"]
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9-]{2,63}$"
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "display_name", "boundary_reference"],
      "properties": {
        "field_id": { "enum": ["FIELD-DEMO-001", "FIELD-DEMO-002"] },
        "display_name": { "enum": ["Field 1", "Field 2"] },
        "boundary_reference": {
          "type": "string",
          "pattern": "^local-reference:[a-z0-9-]{1,48}$"
        }
      }
    },
    "rover": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rover_id",
        "current_field_id",
        "current_unit_id",
        "official_state",
        "battery_percentage",
        "last_seen_tick",
        "fault",
        "active_mission_id",
        "communication_available"
      ],
      "properties": {
        "rover_id": { "enum": ["ROVER-DEMO-001", "ROVER-DEMO-002", "ROVER-DEMO-003"] },
        "current_field_id": { "enum": ["FIELD-DEMO-001", "FIELD-DEMO-002"] },
        "current_unit_id": { "$ref": "#/$defs/identifier" },
        "official_state": { "enum": ["STOPPED", "RUNNING", "RETURNING", "CHARGING"] },
        "battery_percentage": { "type": "integer", "minimum": 0, "maximum": 100 },
        "last_seen_tick": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
        "fault": { "type": "string", "maxLength": 128 },
        "active_mission_id": { "type": "string", "maxLength": 64 },
        "communication_available": { "type": "boolean" }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tick", "event_type", "target_id", "payload"],
      "properties": {
        "tick": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
        "event_type": {
          "enum": [
            "BATTERY_SET",
            "BATTERY_DECREASE",
            "ROVER_SEEN",
            "COMMUNICATION_LOST",
            "COMMUNICATION_RESTORED",
            "FAULT_SET",
            "FAULT_CLEAR",
            "STOP_REQUEST",
            "RETURN_REQUEST",
            "MISSION_CREATE",
            "MISSION_APPROVE",
            "MISSION_ASSIGN",
            "MISSION_START",
            "MISSION_PAUSE",
            "MISSION_CANCEL",
            "CHARGE_START",
            "CHARGE_COMPLETE",
            "FIELD_SWITCH_REQUEST",
            "STATION_RESTART"
          ]
        },
        "target_id": { "$ref": "#/$defs/identifier" },
        "payload": { "type": "object" }
      },
      "allOf": [
        { "$ref": "#/$defs/whenBatterySet" },
        { "$ref": "#/$defs/whenBatteryDecrease" },
        { "$ref": "#/$defs/whenEmptyPayload" },
        { "$ref": "#/$defs/whenFaultSet" },
        { "$ref": "#/$defs/whenReasonPayload" },
        { "$ref": "#/$defs/whenMissionCreate" },
        { "$ref": "#/$defs/whenMissionApprove" },
        { "$ref": "#/$defs/whenMissionAssign" },
        { "$ref": "#/$defs/whenChargeComplete" },
        { "$ref": "#/$defs/whenFieldSwitch" }
      ]
    },
    "emptyPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "maxProperties": 0
    },
    "batteryPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["battery_percentage"],
      "properties": {
        "battery_percentage": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "decreasePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount"],
      "properties": {
        "amount": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "faultPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fault"],
      "properties": { "fault": { "type": "string", "minLength": 1, "maxLength": 128 } }
    },
    "reasonPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "properties": { "reason": { "type": "string", "minLength": 1, "maxLength": 128 } }
    },
    "missionCreatePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "unit_id"],
      "properties": {
        "field_id": { "enum": ["FIELD-DEMO-001", "FIELD-DEMO-002"] },
        "unit_id": { "$ref": "#/$defs/identifier" }
      }
    },
    "approvalPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator_approved"],
      "properties": { "operator_approved": { "const": true } }
    },
    "assignmentPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rover_id"],
      "properties": {
        "rover_id": { "enum": ["ROVER-DEMO-001", "ROVER-DEMO-002", "ROVER-DEMO-003"] }
      }
    },
    "fieldSwitchPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator_confirmed"],
      "properties": { "operator_confirmed": { "const": true } }
    },
    "whenBatterySet": {
      "if": { "properties": { "event_type": { "const": "BATTERY_SET" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/batteryPayload" } } }
    },
    "whenBatteryDecrease": {
      "if": { "properties": { "event_type": { "const": "BATTERY_DECREASE" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/decreasePayload" } } }
    },
    "whenEmptyPayload": {
      "if": {
        "properties": {
          "event_type": {
            "enum": ["ROVER_SEEN", "COMMUNICATION_LOST", "COMMUNICATION_RESTORED", "FAULT_CLEAR", "MISSION_START", "CHARGE_START", "STATION_RESTART"]
          }
        },
        "required": ["event_type"]
      },
      "then": { "properties": { "payload": { "$ref": "#/$defs/emptyPayload" } } }
    },
    "whenFaultSet": {
      "if": { "properties": { "event_type": { "const": "FAULT_SET" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/faultPayload" } } }
    },
    "whenReasonPayload": {
      "if": {
        "properties": { "event_type": { "enum": ["STOP_REQUEST", "RETURN_REQUEST", "MISSION_PAUSE", "MISSION_CANCEL"] } },
        "required": ["event_type"]
      },
      "then": { "properties": { "payload": { "$ref": "#/$defs/reasonPayload" } } }
    },
    "whenMissionCreate": {
      "if": { "properties": { "event_type": { "const": "MISSION_CREATE" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/missionCreatePayload" } } }
    },
    "whenMissionApprove": {
      "if": { "properties": { "event_type": { "const": "MISSION_APPROVE" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/approvalPayload" } } }
    },
    "whenMissionAssign": {
      "if": { "properties": { "event_type": { "const": "MISSION_ASSIGN" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/assignmentPayload" } } }
    },
    "whenChargeComplete": {
      "if": { "properties": { "event_type": { "const": "CHARGE_COMPLETE" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/batteryPayload" } } }
    },
    "whenFieldSwitch": {
      "if": { "properties": { "event_type": { "const": "FIELD_SWITCH_REQUEST" } }, "required": ["event_type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/fieldSwitchPayload" } } }
    }
  }
}
