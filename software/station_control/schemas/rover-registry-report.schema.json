{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rover-registry-report.schema.json",
  "title": "ST-006 Rover Registry Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["report_version", "phase", "session_id", "result", "database", "transaction", "schema", "operations", "rovers", "field_permissions", "unit_permissions", "authorization_decisions", "integrity", "idempotency", "safety", "summary", "diagnostics", "canonical_state_sha256", "exit_code"],
  "properties": {
    "report_version": {"const": 1},
    "phase": {"const": "ST-006"},
    "session_id": {"type": "string", "minLength": 1, "maxLength": 64},
    "result": {"enum": ["PASS", "FAIL"]},
    "database": {"$ref": "#/$defs/database"},
    "transaction": {"$ref": "#/$defs/transaction"},
    "schema": {"$ref": "#/$defs/schema"},
    "operations": {"$ref": "#/$defs/operations"},
    "rovers": {"$ref": "#/$defs/rovers"},
    "field_permissions": {"$ref": "#/$defs/permissions"},
    "unit_permissions": {"$ref": "#/$defs/permissions"},
    "authorization_decisions": {"$ref": "#/$defs/decisions"},
    "integrity": {"$ref": "#/$defs/integrity"},
    "idempotency": {"$ref": "#/$defs/idempotency"},
    "safety": {"$ref": "#/$defs/safety"},
    "summary": {"$ref": "#/$defs/summary"},
    "diagnostics": {"type": "array", "maxItems": 64, "items": {"$ref": "#/$defs/diagnostic"}},
    "canonical_state_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$", "maxLength": 64},
    "exit_code": {"enum": [0, 2, 3, 4, 5, 7]}
  },
  "allOf": [
    {"if": {"properties": {"result": {"const": "PASS"}}, "required": ["result"]}, "then": {"properties": {"exit_code": {"const": 0}}}},
    {"if": {"properties": {"result": {"const": "FAIL"}}, "required": ["result"]}, "then": {"properties": {"exit_code": {"enum": [2, 3, 4, 5, 7]}}}}
  ],
  "$defs": {
    "count512": {"type": "integer", "minimum": 0, "maximum": 512},
    "database": {"type": "object", "additionalProperties": false, "required": ["created", "reopened", "database_outside_repository", "journal_mode", "synchronous", "foreign_keys", "busy_timeout_ms"], "properties": {"created": {"type": "boolean"}, "reopened": {"type": "boolean"}, "database_outside_repository": {"const": true}, "journal_mode": {"enum": ["", "wal"]}, "synchronous": {"enum": ["", "FULL"]}, "foreign_keys": {"type": "boolean"}, "busy_timeout_ms": {"type": "integer", "minimum": 0, "maximum": 5000}}},
    "transaction": {"type": "object", "additionalProperties": false, "required": ["atomic_session", "begun", "committed", "rolled_back"], "properties": {"atomic_session": {"const": true}, "begun": {"type": "boolean"}, "committed": {"type": "boolean"}, "rolled_back": {"type": "boolean"}}},
    "schema": {"type": "object", "additionalProperties": false, "required": ["schema_version", "supported", "initialized", "migration_performed"], "properties": {"schema_version": {"type": "integer", "minimum": 0, "maximum": 1}, "supported": {"type": "boolean"}, "initialized": {"type": "boolean"}, "migration_performed": {"const": false}}},
    "operations": {"type": "object", "additionalProperties": false, "required": ["input_count", "processed_count", "applied_count", "duplicate_noop_count", "rejected_count"], "properties": {"input_count": {"$ref": "#/$defs/count512"}, "processed_count": {"$ref": "#/$defs/count512"}, "applied_count": {"$ref": "#/$defs/count512"}, "duplicate_noop_count": {"$ref": "#/$defs/count512"}, "rejected_count": {"$ref": "#/$defs/count512"}}},
    "rovers": {"type": "object", "additionalProperties": false, "required": ["created_count", "revised_count", "state_changed_count", "pending_count", "registered_count", "suspended_count", "revoked_count", "enabled_count", "disabled_count", "total_count"], "properties": {"created_count": {"type": "integer", "minimum": 0, "maximum": 128}, "revised_count": {"$ref": "#/$defs/count512"}, "state_changed_count": {"$ref": "#/$defs/count512"}, "pending_count": {"type": "integer", "minimum": 0, "maximum": 128}, "registered_count": {"type": "integer", "minimum": 0, "maximum": 128}, "suspended_count": {"type": "integer", "minimum": 0, "maximum": 128}, "revoked_count": {"type": "integer", "minimum": 0, "maximum": 128}, "enabled_count": {"type": "integer", "minimum": 0, "maximum": 128}, "disabled_count": {"type": "integer", "minimum": 0, "maximum": 128}, "total_count": {"type": "integer", "minimum": 0, "maximum": 128}}},
    "permissions": {"type": "object", "additionalProperties": false, "required": ["created_count", "total_count", "enabled_count"], "properties": {"created_count": {"type": "integer", "minimum": 0, "maximum": 8192}, "total_count": {"type": "integer", "minimum": 0, "maximum": 8192}, "enabled_count": {"type": "integer", "minimum": 0, "maximum": 8192}}},
    "decisions": {"type": "object", "additionalProperties": false, "required": ["created_count", "total_count", "authorized_count", "denied_count", "direct_output_authority"], "properties": {"created_count": {"type": "integer", "minimum": 0, "maximum": 256}, "total_count": {"type": "integer", "minimum": 0, "maximum": 100000}, "authorized_count": {"type": "integer", "minimum": 0, "maximum": 100000}, "denied_count": {"type": "integer", "minimum": 0, "maximum": 100000}, "direct_output_authority": {"const": false}}},
    "integrity": {"type": "object", "additionalProperties": false, "required": ["check_performed", "result"], "properties": {"check_performed": {"type": "boolean"}, "result": {"enum": ["OK", "FAILED", "NOT_PERFORMED"]}}},
    "idempotency": {"type": "object", "additionalProperties": false, "required": ["request_hash_algorithm", "duplicate_noop_count", "conflict_count"], "properties": {"request_hash_algorithm": {"const": "SHA256_CANONICAL_JSON"}, "duplicate_noop_count": {"$ref": "#/$defs/count512"}, "conflict_count": {"$ref": "#/$defs/count512"}}},
    "safety": {"type": "object", "additionalProperties": false, "required": ["offline_only", "network_access_performed", "gpio_access_performed", "serial_access_performed", "hardware_output_performed", "motor_control_performed", "charging_control_performed", "rover_communication_performed", "actual_assignment_performed", "actual_arm_performed", "field_navigation_performed", "cryptographic_authentication_performed", "automatic_registration_performed", "automatic_state_transition_performed", "direct_output_authority", "repository_modified", "physical_estop_independent"], "properties": {"offline_only": {"const": true}, "network_access_performed": {"const": false}, "gpio_access_performed": {"const": false}, "serial_access_performed": {"const": false}, "hardware_output_performed": {"const": false}, "motor_control_performed": {"const": false}, "charging_control_performed": {"const": false}, "rover_communication_performed": {"const": false}, "actual_assignment_performed": {"const": false}, "actual_arm_performed": {"const": false}, "field_navigation_performed": {"const": false}, "cryptographic_authentication_performed": {"const": false}, "automatic_registration_performed": {"const": false}, "automatic_state_transition_performed": {"const": false}, "direct_output_authority": {"const": false}, "repository_modified": {"const": false}, "physical_estop_independent": {"const": true}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["table_count", "row_count_total", "diagnostic_count", "authorized_decision_count", "denied_decision_count", "next_phase_eligible"], "properties": {"table_count": {"const": 6}, "row_count_total": {"type": "integer", "minimum": 0, "maximum": 100000}, "diagnostic_count": {"type": "integer", "minimum": 0, "maximum": 64}, "authorized_decision_count": {"type": "integer", "minimum": 0, "maximum": 100000}, "denied_decision_count": {"type": "integer", "minimum": 0, "maximum": 100000}, "next_phase_eligible": {"type": "boolean"}}},
    "diagnostic": {"type": "object", "additionalProperties": false, "required": ["severity", "code", "component", "operation_id", "message"], "properties": {"severity": {"enum": ["INFO", "WARNING", "ERROR"]}, "code": {"enum": ["ROVER_INVALID_ARGUMENT", "ROVER_REPOSITORY_ROOT_INVALID", "ROVER_DATABASE_PATH_INSIDE_REPOSITORY", "ROVER_DATABASE_PARENT_INVALID", "ROVER_REPORT_PATH_INSIDE_REPOSITORY", "ROVER_REPORT_PARENT_INVALID", "ROVER_SESSION_INVALID", "ROVER_SESSION_TICK_REVERSED", "ROVER_SCHEMA_VERSION_UNSUPPORTED", "ROVER_SCHEMA_INITIALIZATION_FAILED", "ROVER_TRANSACTION_BEGIN_FAILED", "ROVER_OPERATION_UNKNOWN", "ROVER_IDEMPOTENCY_CONFLICT", "ROVER_ALREADY_EXISTS", "ROVER_NOT_FOUND", "ROVER_REVISION_CONFLICT", "ROVER_REVISION_SEQUENCE_INVALID", "ROVER_PROFILE_INVALID", "ROVER_FIELD_PERMISSION_DUPLICATE", "ROVER_UNIT_PERMISSION_DUPLICATE", "ROVER_STATE_TRANSITION_INVALID", "ROVER_OPERATOR_APPROVAL_REQUIRED", "ROVER_NOT_STOPPED", "ROVER_ACTIVE_MISSION_PRESENT", "ROVER_CHARGING_TRANSITION_ACTIVE", "ROVER_AUTHORIZATION_ID_CONFLICT", "ROVER_TRANSACTION_ROLLED_BACK", "ROVER_INTEGRITY_CHECK_FAILED", "ROVER_REOPEN_FAILED", "ROVER_REPORT_WRITE_FAILED", "ROVER_INTERNAL_ERROR"]}, "component": {"type": "string", "minLength": 1, "maxLength": 32}, "operation_id": {"type": "string", "maxLength": 32}, "message": {"type": "string", "minLength": 1, "maxLength": 256}}}
  }
}
