      "required": ["policy", "daily_window_minutes", "operator_count", "vehicle_rover_capacity", "battery_pool_count", "required_speed_found", "required_speed_mm_per_min", "reason"],
      "properties": {
        "policy": {"$ref": "#/$defs/policy"},
        "daily_window_minutes": {"enum": [150, 300, 480]},
        "operator_count": {"enum": [1, 2, 3]},
