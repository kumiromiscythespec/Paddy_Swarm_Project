      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "rover_count"],
      "properties": {"field_id": {"type": "string", "minLength": 1, "maxLength": 32}, "rover_count": {"type": "integer", "minimum": 1, "maximum": 60}}
