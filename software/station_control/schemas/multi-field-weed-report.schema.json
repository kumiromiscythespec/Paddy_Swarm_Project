{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "multi-field-weed-report.schema.json",
  "title": "ST-010 deterministic multi-field weed scheduler report",
  "type": "object",
  "additionalProperties": false,
  "required": ["report_version", "phase", "plan_id", "result", "area_reference", "operational_field_model", "fleet_model", "logistics_model", "battery_model", "search_space", "configuration_results", "selected_results", "required_capacity", "feasibility", "safety", "diagnostics", "canonical_plan_sha256", "canonical_schedule_state_sha256", "exit_code"],
  "properties": {
    "report_version": {"const": 1},
    "phase": {"const": "ST-010"},
    "plan_id": {"const": "ST010-MULTI-FIELD-WEED-DEMO"},
    "result": {"enum": ["PASS", "FAIL"]},
    "area_reference": {"$ref": "#/$defs/area_reference"},
    "operational_field_model": {"$ref": "#/$defs/operational_model"},
    "fleet_model": {"$ref": "#/$defs/fleet_model"},
    "logistics_model": {"$ref": "#/$defs/logistics_model"},
    "battery_model": {"$ref": "#/$defs/battery_model"},
    "search_space": {"$ref": "#/$defs/search_space"},
    "configuration_results": {"type": "array", "minItems": 1215, "maxItems": 1215, "items": {"$ref": "#/$defs/configuration_result"}},
    "selected_results": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"$ref": "#/$defs/selected_result"}},
    "required_capacity": {"$ref": "#/$defs/required_capacity"},
    "feasibility": {"$ref": "#/$defs/feasibility"},
    "safety": {"$ref": "#/$defs/safety"},
    "diagnostics": {"type": "array", "minItems": 0, "maxItems": 5000, "items": {"$ref": "#/$defs/diagnostic"}},
    "canonical_plan_sha256": {"$ref": "#/$defs/sha256"},
    "canonical_schedule_state_sha256": {"$ref": "#/$defs/sha256"},
    "exit_code": {"enum": [0, 2, 3, 4, 7]}
  },
  "$defs": {
    "nonnegative": {"type": "integer", "minimum": 0, "maximum": 1000000000},
    "positive": {"type": "integer", "minimum": 1, "maximum": 1000000000},
    "basis_points": {"type": "integer", "minimum": 0, "maximum": 10000},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "group_id": {"enum": ["GROUP-HOME", "GROUP-OTHER-CONSIGNED", "GROUP-CONSIGNED", "GROUP-OWN-A", "GROUP-OWN-B"]},
    "policy": {"enum": ["ONE_FIELD_CONCENTRATED", "TWO_FIELDS_EQUAL", "TWO_FIELDS_WEIGHTED", "FINISH_FIRST", "ROAD_SIDE_BATCHED"]},
    "bottleneck": {"enum": ["NONE", "WORKDAY_TOO_SHORT", "SPEED_INSUFFICIENT", "ROVER_COUNT_INSUFFICIENT", "VEHICLE_CAPACITY", "MANUAL_LOADING_TIME", "STATION_RELOCATION", "GROUP_TRANSFER", "BATTERY_POOL", "CHARGER_COUNT", "BATTERY_RUNTIME", "NO_MIDDAY_BATTERY_DELIVERY", "FIELD_GEOMETRY_ESTIMATED", "FIELD_AREA_MAPPING_UNRESOLVED"]},
    "recommendation": {"enum": ["MEASURE_ACTUAL_19_FIELD_AREAS", "RESOLVE_R4_TO_CURRENT_FIELD_MAPPING", "MEASURE_ROVER_LOADING_CAPACITY", "MEASURE_ROVER_OPERATING_SPEED", "MEASURE_WEED_POWER_CONSUMPTION", "INCREASE_DAILY_WORK_WINDOW", "INCREASE_EFFECTIVE_SPEED", "INCREASE_WEED_ROVER_COUNT", "INCREASE_BATTERY_POOL", "INCREASE_CHARGER_COUNT", "REDUCE_FIELD_TRANSFER_FREQUENCY", "USE_ROAD_SIDE_BATCHED_OPERATION", "ADD_SECOND_MOBILE_STATION_FOR_PARALLEL_FIELDS", "CONSIDER_MIDDAY_BATTERY_SHUTTLE", "MANUAL_DRONE_SCOUT_SEPARATE_STUDY", "PHYSICAL_FIELD_VALIDATION_REQUIRED"]},
    "area_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference_id", "mapping_status", "r4_total_area_m2", "r4_parcel_count", "r4_rice_area_m2", "r4_rice_parcel_count", "r4_rice_parcel_areas_m2", "r4_grass_parcel_areas_m2", "r4_self_conservation_area_m2"],
      "properties": {
        "reference_id": {"const": "R4_DECLARED_AREA_REFERENCE"},
        "mapping_status": {"const": "UNRESOLVED"},
        "r4_total_area_m2": {"const": 31950},
        "r4_parcel_count": {"const": 20},
        "r4_rice_area_m2": {"const": 22040},
        "r4_rice_parcel_count": {"const": 16},
        "r4_rice_parcel_areas_m2": {"type": "array", "minItems": 16, "maxItems": 16, "items": {"$ref": "#/$defs/positive"}},
        "r4_grass_parcel_areas_m2": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/positive"}},
        "r4_self_conservation_area_m2": {"const": 3130}
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group_id", "field_count"],
      "properties": {"group_id": {"$ref": "#/$defs/group_id"}, "field_count": {"type": "integer", "minimum": 2, "maximum": 9}}
    },
    "normalized_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "group_id", "area_m2", "target_distance_mm"],
      "properties": {
        "field_id": {"type": "string", "pattern": "^GROUP-[A-Z-]+-F[0-9]{2}$", "maxLength": 32},
        "group_id": {"$ref": "#/$defs/group_id"},
        "area_m2": {"type": "integer", "minimum": 1421, "maximum": 1422},
        "target_distance_mm": {"enum": [5447167, 5451000]}
      }
    },
    "operational_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_model_id", "field_count", "total_area_m2", "area_source", "parcel_mapping_status", "field_area_estimated", "field_geometry_estimated", "actual_field_measurement_required", "area_level_target_distance_mm", "field_level_target_distance_mm", "groups", "fields"],
      "properties": {
        "field_model_id": {"const": "CURRENT_OPERATIONAL_EQUALIZED_19"},
        "field_count": {"const": 19},
        "total_area_m2": {"const": 27000},
        "area_source": {"const": "TOTAL_ONLY_EQUALIZED_ESTIMATE"},
        "parcel_mapping_status": {"const": "UNRESOLVED"},
        "field_area_estimated": {"const": true},
        "field_geometry_estimated": {"const": true},
        "actual_field_measurement_required": {"const": true},
        "area_level_target_distance_mm": {"const": 103500000},
        "field_level_target_distance_mm": {"const": 103500006},
        "groups": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"$ref": "#/$defs/group"}},
        "fields": {"type": "array", "minItems": 19, "maxItems": 19, "items": {"$ref": "#/$defs/normalized_field"}}
      }
    },
    "fleet_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weed_rover_count", "maximum_simultaneous_fields", "manual_rover_transfer", "rover_states"],
      "properties": {
        "weed_rover_count": {"const": 12},
        "maximum_simultaneous_fields": {"const": 2},
        "manual_rover_transfer": {"const": true},
        "rover_states": {"const": ["AT_DEPOT", "IN_MANUAL_TRANSPORT", "DEPLOYED", "WORKING", "BATTERY_SWAP", "BATTERY_WAIT", "MANUAL_RECOVERY", "MAINTENANCE", "DONE_FOR_DAY"]}
      }
    },
    "logistics_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vehicle_count", "operator_count_options", "vehicle_rover_capacity_options", "vehicle_capacity_provisional_upper_bound", "manual_station_transfer", "station_requires_dedicated_trip", "maximum_group_changes_per_day", "morning_deployment_required", "daily_recovery_required"],
      "properties": {
        "vehicle_count": {"const": 1},
        "operator_count_options": {"const": [1, 2, 3]},
        "vehicle_rover_capacity_options": {"const": [6, 8, 10]},
        "vehicle_capacity_provisional_upper_bound": {"const": true},
        "manual_station_transfer": {"const": true},
        "station_requires_dedicated_trip": {"const": true},
        "maximum_group_changes_per_day": {"const": 1},
        "morning_deployment_required": {"const": true},
        "daily_recovery_required": {"const": true}
      }
    },
    "battery_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["battery_id", "battery_pool_options", "charger_count", "battery_runtime_minutes", "battery_swap_minutes", "charge_minutes", "overnight_charge_window_minutes", "maximum_overnight_sessions", "service_windows", "midday_battery_shuttle_enabled", "state_carried_across_days", "daily_battery_reset", "mobile_charging_station_count"],
      "properties": {
        "battery_id": {"const": "BATTERY-DEMO-LIFEPO4-12V-10AH"},
        "battery_pool_options": {"const": [16, 24, 36]},
        "charger_count": {"const": 4},
        "battery_runtime_minutes": {"const": 150},
        "battery_swap_minutes": {"const": 3},
        "charge_minutes": {"const": 180},
        "overnight_charge_window_minutes": {"const": 720},
        "maximum_overnight_sessions": {"const": 16},
        "service_windows": {"const": ["MORNING_DEPLOYMENT", "EVENING_RECOVERY"]},
        "midday_battery_shuttle_enabled": {"const": false},
        "state_carried_across_days": {"const": true},
        "daily_battery_reset": {"const": false},
        "mobile_charging_station_count": {"const": 1}
      }
    },
    "search_space": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allocation_policy_count", "speed_profile_count", "daily_window_count", "operator_count", "vehicle_capacity_count", "battery_pool_count", "raw_configuration_count", "all_configurations_evaluated", "random_sampling", "automatic_range_reduction"],
      "properties": {
        "allocation_policy_count": {"const": 5},
        "speed_profile_count": {"const": 3},
        "daily_window_count": {"const": 3},
        "operator_count": {"const": 3},
        "vehicle_capacity_count": {"const": 3},
        "battery_pool_count": {"const": 3},
        "raw_configuration_count": {"const": 1215},
        "all_configurations_evaluated": {"const": true},
        "random_sampling": {"const": false},
        "automatic_range_reduction": {"const": false}
      }
