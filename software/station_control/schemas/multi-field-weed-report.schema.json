    "field_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "group_id", "area_m2", "area_estimated", "target_distance_mm", "processed_distance_mm", "remaining_distance_mm", "completion_basis_points", "status", "first_work_day", "completion_day", "interruption_count", "deployment_count", "battery_wait_minutes"],
      "properties": {
        "field_id": {"type": "string", "minLength": 1, "maxLength": 32},
        "group_id": {"$ref": "#/$defs/group_id"},
        "area_m2": {"type": "integer", "minimum": 1421, "maximum": 1422},
        "area_estimated": {"const": true},
        "target_distance_mm": {"enum": [5447167, 5451000]},
        "processed_distance_mm": {"$ref": "#/$defs/nonnegative"},
        "remaining_distance_mm": {"$ref": "#/$defs/nonnegative"},
        "completion_basis_points": {"$ref": "#/$defs/basis_points"},
        "status": {"enum": ["WAITING", "IN_PROGRESS", "COMPLETED", "MANUAL_REQUIRED"]},
        "first_work_day": {"type": "integer", "minimum": 0, "maximum": 10},
        "completion_day": {"type": "integer", "minimum": 0, "maximum": 10},
        "interruption_count": {"$ref": "#/$defs/nonnegative"},
        "deployment_count": {"$ref": "#/$defs/nonnegative"},
        "battery_wait_minutes": {"$ref": "#/$defs/nonnegative"}
      }
    },
    "daily_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["day_index", "selected_group_ids", "selected_field_ids", "rover_allocations", "morning_full_batteries", "evening_depleted_batteries", "overnight_charged_batteries", "deployment_minutes", "productive_minutes", "recovery_minutes", "processed_distance_mm", "completed_field_ids", "group_change_count", "vehicle_trip_count", "station_trip_count", "battery_swap_count", "battery_wait_minutes", "human_work_minutes"],
      "properties": {
        "day_index": {"type": "integer", "minimum": 1, "maximum": 10},
        "selected_group_ids": {"type": "array", "minItems": 1, "maxItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/group_id"}},
        "selected_field_ids": {"type": "array", "minItems": 0, "maxItems": 19, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 32}},
        "rover_allocations": {"type": "array", "minItems": 0, "maxItems": 19, "items": {"$ref": "#/$defs/rover_allocation"}},
        "morning_full_batteries": {"$ref": "#/$defs/nonnegative"},
        "evening_depleted_batteries": {"$ref": "#/$defs/nonnegative"},
        "overnight_charged_batteries": {"$ref": "#/$defs/nonnegative"},
        "deployment_minutes": {"$ref": "#/$defs/nonnegative"},
        "productive_minutes": {"type": "integer", "minimum": 0, "maximum": 480},
        "recovery_minutes": {"$ref": "#/$defs/nonnegative"},
        "processed_distance_mm": {"$ref": "#/$defs/nonnegative"},
        "completed_field_ids": {"type": "array", "minItems": 0, "maxItems": 19, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 32}},
        "group_change_count": {"type": "integer", "minimum": 0, "maximum": 1},
        "vehicle_trip_count": {"$ref": "#/$defs/nonnegative"},
        "station_trip_count": {"$ref": "#/$defs/nonnegative"},
        "battery_swap_count": {"$ref": "#/$defs/nonnegative"},
        "battery_wait_minutes": {"$ref": "#/$defs/nonnegative"},
        "human_work_minutes": {"$ref": "#/$defs/nonnegative"}
      }
    },
    "configuration_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["configuration_id", "policy", "speed_profile", "speed_mm_per_min", "daily_window_minutes", "operator_count", "vehicle_rover_capacity", "battery_pool_count", "completed", "completed_field_count", "completed_area_m2", "incomplete_area_m2", "processed_distance_mm", "target_distance_mm", "completion_basis_points", "days_used", "estimated_days_required", "required_speed_found", "required_speed_mm_per_min", "field_transfer_count", "group_transfer_count", "vehicle_trip_count", "station_trip_count", "battery_swap_count", "battery_wait_minutes", "minimum_charged_inventory", "human_work_minutes", "maximum_daily_human_work_minutes", "field_results", "daily_results", "bottlenecks", "recommendations"],
      "properties": {
        "configuration_id": {"type": "string", "pattern": "^CFG-[A-Z_]+-S[0-9]{4}-D[0-9]{4}-O[0-9]{2}-V[0-9]{2}-B[0-9]{2}$", "maxLength": 96},
        "policy": {"$ref": "#/$defs/policy"},
        "speed_profile": {"enum": ["CONSERVATIVE", "CURRENT_STANDARD", "CURRENT_IMPROVED"]},
        "speed_mm_per_min": {"enum": [400, 700, 1000]},
        "daily_window_minutes": {"enum": [150, 300, 480]},
        "operator_count": {"enum": [1, 2, 3]},
        "vehicle_rover_capacity": {"enum": [6, 8, 10]},
        "battery_pool_count": {"enum": [16, 24, 36]},
        "completed": {"type": "boolean"},
        "completed_field_count": {"type": "integer", "minimum": 0, "maximum": 19},
        "completed_area_m2": {"type": "integer", "minimum": 0, "maximum": 27000},
        "incomplete_area_m2": {"type": "integer", "minimum": 0, "maximum": 27000},
        "processed_distance_mm": {"type": "integer", "minimum": 0, "maximum": 103500006},
        "target_distance_mm": {"const": 103500006},
        "completion_basis_points": {"$ref": "#/$defs/basis_points"},
        "days_used": {"type": "integer", "minimum": 0, "maximum": 10},
        "estimated_days_required": {"$ref": "#/$defs/nonnegative"},
        "required_speed_found": {"type": "boolean"},
        "required_speed_mm_per_min": {"type": "integer", "minimum": 0, "maximum": 10000},
        "field_transfer_count": {"$ref": "#/$defs/nonnegative"},
        "group_transfer_count": {"$ref": "#/$defs/nonnegative"},
        "vehicle_trip_count": {"$ref": "#/$defs/nonnegative"},
        "station_trip_count": {"$ref": "#/$defs/nonnegative"},
        "battery_swap_count": {"$ref": "#/$defs/nonnegative"},
        "battery_wait_minutes": {"$ref": "#/$defs/nonnegative"},
        "minimum_charged_inventory": {"$ref": "#/$defs/nonnegative"},
        "human_work_minutes": {"$ref": "#/$defs/nonnegative"},
        "maximum_daily_human_work_minutes": {"$ref": "#/$defs/nonnegative"},
        "field_results": {"type": "array", "minItems": 19, "maxItems": 19, "items": {"$ref": "#/$defs/field_result"}},
        "daily_results": {"type": "array", "minItems": 1, "maxItems": 10, "items": {"$ref": "#/$defs/daily_result"}},
        "bottlenecks": {"type": "array", "minItems": 1, "maxItems": 14, "uniqueItems": true, "items": {"$ref": "#/$defs/bottleneck"}},
        "recommendations": {"type": "array", "minItems": 3, "maxItems": 16, "uniqueItems": true, "items": {"$ref": "#/$defs/recommendation"}}
      }
    },
    "selected_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selection_id", "configuration_id"],
      "properties": {
        "selection_id": {"enum": ["BEST_COMPLETION", "MINIMUM_HUMAN_TIME", "MINIMUM_TRANSFER", "BEST_10_DAY_FEASIBILITY"]},
        "configuration_id": {"type": "string", "minLength": 1, "maxLength": 96}
      }
