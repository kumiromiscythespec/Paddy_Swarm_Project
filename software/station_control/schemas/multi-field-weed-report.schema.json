      "properties": {
        "required_speed_is_design_target": {"const": true},
        "actual_speed_measurement_required": {"const": true},
        "required_speed_results": {"type": "array", "minItems": 405, "maxItems": 405, "items": {"$ref": "#/$defs/required_speed_result"}},
        "representative_policy": {"const": "ROAD_SIDE_BATCHED"},
