      "additionalProperties": false,
      "required": ["offline_only", "network_access_performed", "random_used", "monte_carlo_used", "weather_probability_claimed", "gpio_access_performed", "serial_access_performed", "hardware_output_performed", "motor_control_performed", "pto_control_performed", "charging_control_performed", "bms_communication_performed", "rover_communication_performed", "actual_assignment_performed", "actual_arm_performed", "autonomous_interfield_transfer_performed", "autonomous_public_road_crossing_performed", "rover_carried_station_transfer_performed", "field_operation_approved", "unattended_operation_approved", "physical_estop_independent", "repository_modified"],
      "properties": {
        "offline_only": {"const": true},
        "network_access_performed": {"const": false},
        "random_used": {"const": false},
        "monte_carlo_used": {"const": false},
        "weather_probability_claimed": {"const": false},
        "gpio_access_performed": {"const": false},
        "serial_access_performed": {"const": false},
        "hardware_output_performed": {"const": false},
        "motor_control_performed": {"const": false},
        "pto_control_performed": {"const": false},
        "charging_control_performed": {"const": false},
        "bms_communication_performed": {"const": false},
        "rover_communication_performed": {"const": false},
        "actual_assignment_performed": {"const": false},
        "actual_arm_performed": {"const": false},
        "autonomous_interfield_transfer_performed": {"const": false},
        "autonomous_public_road_crossing_performed": {"const": false},
        "rover_carried_station_transfer_performed": {"const": false},
        "field_operation_approved": {"const": false},
        "unattended_operation_approved": {"const": false},
        "physical_estop_independent": {"const": true},
        "repository_modified": {"const": false}
