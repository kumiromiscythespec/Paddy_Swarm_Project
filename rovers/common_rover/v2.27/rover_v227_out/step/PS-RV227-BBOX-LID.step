GLOBAL_UNIT_ASSIGNED_CONTEXT((#27048,#27049,#27050)) 
REPRESENTATION_CONTEXT('Context #1',
  '3D Context with UNIT and UNCERTAINTY') );
#27048 = ( LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.) );
